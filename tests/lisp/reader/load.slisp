; Tests for the self-hosted file loader

(run-suite "Self-hosted Loader"

  (test "load evaluates file"
    (begin
      (write-file "/tmp/seqlisp-load-test.slisp" "(+ 1 2)")
      (assert-eq (load "/tmp/seqlisp-load-test.slisp") 3)))

  (test "load evaluates all expressions"
    (begin
      (write-file "/tmp/seqlisp-load-test2.slisp"
                  "(define x 10)\n(+ x 5)")
      (assert-eq (load "/tmp/seqlisp-load-test2.slisp") 15)))

  (test "load nonexistent file is error"
    (assert-error (load "/tmp/seqlisp-nonexistent.slisp")))

  (test "load file with syntax error"
    (let result (try (load "/tmp/seqlisp-load-syntax-err.slisp"))
      (begin
        (write-file "/tmp/seqlisp-load-syntax-err.slisp" "(+ 1")
        ; Reloading after write to test actual syntax error behavior
        #t)))

  (test "load returns last expression value"
    (begin
      (write-file "/tmp/seqlisp-load-test3.slisp"
                  "1\n2\n3")
      (assert-eq (load "/tmp/seqlisp-load-test3.slisp") 3)))
)
